{
  "name": "aime-desktop-task-companion",
  "version": "0.1.0",
  "private": true,
  "description": "Mac-first desktop task companion for Aime todo monitoring.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 6173 --strictPort",
    "lark:init": "node scripts/aime-lark-sync.mjs init",
    "lark:setup": "node scripts/aime-lark-sync.mjs setup",
    "lark:setup-status": "node scripts/aime-lark-sync.mjs setup-status",
    "lark:bind-assistant": "node scripts/aime-lark-sync.mjs bind-assistant",
    "lark:search-and-bind-assistant": "node scripts/aime-lark-sync.mjs search-and-bind-assistant",
    "lark:config": "node scripts/aime-lark-sync.mjs config",
    "lark:auth-start": "node scripts/aime-lark-sync.mjs auth-start",
    "lark:auth-finish": "node scripts/aime-lark-sync.mjs auth-finish",
    "lark:doctor": "node scripts/aime-lark-sync.mjs doctor",
    "lark:self-test": "node scripts/aime-lark-sync.mjs self-test",
    "lark:fields": "node scripts/aime-lark-sync.mjs fields",
    "lark:migrate-context-fields": "node scripts/aime-lark-sync.mjs migrate-context-fields",
    "lark:pull": "node scripts/aime-lark-sync.mjs pull",
    "lark:assistant-signal": "node scripts/aime-lark-sync.mjs assistant-signal",
    "lark:create": "node scripts/aime-lark-sync.mjs create",
    "lark:complete": "node scripts/aime-lark-sync.mjs complete",
    "lark:ignore": "node scripts/aime-lark-sync.mjs ignore",
    "lark:reschedule": "node scripts/aime-lark-sync.mjs reschedule",
    "lark:update": "node scripts/aime-lark-sync.mjs update",
    "native:build": "mkdir -p .build/module-cache && CLANG_MODULE_CACHE_PATH=\"$PWD/.build/module-cache\" swiftc -target arm64-apple-macosx15.0 native/AimeCompanion/AimeModels.swift native/AimeCompanion/PetState.swift native/AimeCompanion/main.swift -framework AppKit -framework Vision -o .build/aime-companion",
    "native:test": "mkdir -p .build/module-cache && CLANG_MODULE_CACHE_PATH=\"$PWD/.build/module-cache\" swiftc -target arm64-apple-macosx15.0 native/AimeCompanion/AimeModels.swift native/AimeCompanion/PetState.swift native/AimeCompanion/PetStateTests.swift -o .build/pet-state-tests && ./.build/pet-state-tests",
    "native:package": "npm run native:build && node scripts/package-native-app.mjs",
    "native:dist": "npm run native:package && node scripts/package-dist.mjs",
    "native:open": "npm run native:package && open .build/神仙待办.app",
    "native:run": "npm run native:open",
    "build": "vite build && npm run native:build",
    "test": "vitest run && npm run native:test",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
